rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que o usuário leia e escreva apenas em seu próprio documento de perfil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regras para Salas
    match /rooms/{roomId} {
      // Permite criar se estiver autenticado. O ownerId no documento DEVE ser o UID do usuário.
      allow create: if request.auth != null && (request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerId == null);
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.ownerId == request.auth.uid || resource.data.ownerId == null);
    }

    // Regras para Histórico (Escrita via Cloud Functions, leitura via app)
    match /roomHistory/{roomId}/{allPaths=**} {
      allow read: if request.auth != null;
      // Escrita geralmente é feita pelo Backend (Admin SDK ignora regras), 
      // mas mantemos bloqueado para o frontend por segurança.
      allow write: if false;
    }
  }
}
