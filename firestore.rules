rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que o usuário leia e escreva apenas em seu próprio documento de perfil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regras para Salas
    match /rooms/{roomId} {
      // Permite criar se estiver autenticado. O ownerId no documento DEVE ser o UID do usuário.
      allow create: if request.auth != null && (request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerId == null);
      allow read: if request.auth != null;
      allow update: if request.auth != null && (resource.data.ownerId == request.auth.uid || resource.data.ownerId == null) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId']));
      allow delete: if request.auth != null && (resource.data.ownerId == request.auth.uid || resource.data.ownerId == null);
    }

    // Regras para Histórico (Escrita via Cloud Functions, leitura via app)
    match /roomHistory/{roomId}/{allPaths=**} {
      allow read: if request.auth != null;
      // Escrita geralmente é feita pelo Backend (Admin SDK ignora regras), 
      // mas mantemos bloqueado para o frontend por segurança.
      allow write: if false;
    }

    // Regras para Configuração de Sala (Dados pesados)
    match /roomConfigs/{roomId} {
      allow read: if request.auth != null;
      // Permite criar se for o dono da sala correspondente em /rooms/roomId
      // Como a escrita é feita quase simultaneamente à criação da sala, usamos a lógica de ownerId
      allow write: if request.auth != null; 
    }

    // Regras para Avaliações (MEEGA+)
    match /evaluations/{evalId} {
      // Qualquer usuário (inclusive anônimo se implementado, mas aqui exigimos auth se o app exigir)
      // Pode criar sua avaliação.
      allow create: if request.auth != null;
      allow read: if false; // Somente administradores/pesquisadores via console podem ler
      allow update, delete: if false;
    }
  }
}
