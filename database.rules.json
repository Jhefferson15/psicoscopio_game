{
  "rules": {
    "rooms": {
      ".indexOn": ["ownerId"],
      // Permite que o observador liste apenas suas próprias salas via query
      ".read": "auth != null && query.orderByChild === 'ownerId' && query.equalTo === auth.uid",
      "$roomId": {
        // Jogadores individuais ainda precisam ler sua sala específica
        ".read": "auth != null",
        "status": {
          ".write": false
        },
        "ownerId": {
          ".write": "auth != null && !data.exists()"
        },
        "participants": {
          "$userId": {
            ".write": "auth != null && (auth.uid === $userId || root.child('rooms').child($roomId).child('ownerId').val() === auth.uid)"
          }
        },
        "readyPlayers": {
          "$userId": {
            ".write": "auth != null && auth.uid === $userId"
          }
        },
        "gameState": {
          ".read": "auth != null",
          ".write": false
        },
        // Permite criar se não existir OU deletar/editar se for o dono
        ".write": "auth != null && (!data.exists() || data.child('ownerId').val() === auth.uid)"
      }
    }
  }
}