{
  "rules": {
    "rooms": {
      ".indexOn": [
        "ownerId"
      ],
      ".read": "auth != null && query.orderByChild === 'ownerId' && query.equalTo === auth.uid",
      "$roomId": {
        ".read": "auth != null",
        "status": {
          ".write": false
        },
        "ownerId": {
          ".write": "auth != null && !data.exists()"
        },
        "participants": {
          "$userId": {
            ".write": "auth != null && (auth.uid === $userId || root.child('rooms').child($roomId).child('ownerId').val() === auth.uid)"
          }
        },
        "readyPlayers": {
          "$userId": {
            ".write": "auth != null && auth.uid === $userId"
          }
        },
        "gameState": {
          ".read": "auth != null",
          ".write": false
        },
        ".write": "auth != null && ((!data.exists() && newData.child('ownerId').val() === auth.uid) || (data.exists() && data.child('ownerId').val() === auth.uid))"
      }
    }
  }
}